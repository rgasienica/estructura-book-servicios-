{
    "terminal.integrated.defaultProfile.windows": "PowerShell",
    "files.exclude": {
        "**/node_modules": true,
        "**/.git/objects": true,
        "**/.git/modules": true
    },
    "files.watcherExclude": {
        "**/node_modules/**": true,
        "**/.git/objects/**": true
    },
    "mcpServers": {
        "playwright": {
            "command": "npx",
            "args": ["-y", "@playwright/mcp@latest", "--caps=vision"]
        }
    }
}
